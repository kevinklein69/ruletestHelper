{
  "manifest_version": 3,
  "name": "ClassMarker Eishockey Regeltest Helper",
  "version": "1.0.0",
  "description": "Lernt richtige Antworten beim Eishockey-Regeltest auf ClassMarker und füllt sie automatisch aus.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.classmarker.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.classmarker.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
